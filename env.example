"""
Risk / confidence scoring.

Turns raw signals from many sources into a single 0-100 score. The design is
deliberately transparent and auditable: each contributing signal is weighted,
and the breakdown is returned alongside the score so an analyst can see *why*
an entity looks risky — never a black box.
"""
from __future__ import annotations

from dataclasses import dataclass


@dataclass
class Signal:
    name: str
    weight: float          # 0..1 relative importance
    value: float           # 0..1 normalized severity


# Reference weights per signal type. Tune from analyst feedback over time.
DEFAULT_WEIGHTS = {
    "vt_malicious": 0.30,
    "abuseipdb_confidence": 0.20,
    "greynoise_malicious": 0.15,
    "otx_pulses": 0.15,
    "hibp_breaches": 0.10,
    "recent_cert_churn": 0.05,
    "young_domain": 0.05,
}


def score(signals: list[Signal]) -> dict:
    """Weighted mean of normalized signals -> {score, band, breakdown}."""
    if not signals:
        return {"score": 0, "band": "unknown", "breakdown": [], "confidence": 0.0}

    total_w = sum(s.weight for s in signals) or 1.0
    raw = sum(s.weight * max(0.0, min(1.0, s.value)) for s in signals) / total_w
    value = round(raw * 100)

    band = "low" if value < 35 else "medium" if value < 65 else "high"
    # confidence grows with how much of the weight space we actually observed
    coverage = min(1.0, total_w / sum(DEFAULT_WEIGHTS.values()))

    return {
        "score": value,
        "band": band,
        "confidence": round(coverage, 2),
        "breakdown": [
            {"name": s.name, "weight": s.weight,
             "value": round(s.value, 2),
             "contribution": round(s.weight * s.value / total_w * 100, 1)}
            for s in sorted(signals, key=lambda x: -x.weight * x.value)
        ],
    }


def signals_from_provenance(entity_attrs: dict) -> list[Signal]:
    """Map normalized entity attributes to weighted signals."""
    out: list[Signal] = []
    if (m := entity_attrs.get("malicious")) is not None:
        out.append(Signal("vt_malicious", DEFAULT_WEIGHTS["vt_malicious"],
                          min(1.0, float(m) / 5)))
    if (a := entity_attrs.get("abuse_confidence")) is not None:
        out.append(Signal("abuseipdb_confidence", DEFAULT_WEIGHTS["abuseipdb_confidence"],
                          float(a) / 100))
    if entity_attrs.get("greynoise_classification") == "malicious":
        out.append(Signal("greynoise_malicious", DEFAULT_WEIGHTS["greynoise_malicious"], 1.0))
    if (p := entity_attrs.get("otx_pulses")) is not None:
        out.append(Signal("otx_pulses", DEFAULT_WEIGHTS["otx_pulses"], min(1.0, float(p) / 10)))
    if (b := entity_attrs.get("breaches")) is not None:
        out.append(Signal("hibp_breaches", DEFAULT_WEIGHTS["hibp_breaches"], min(1.0, float(b) / 3)))
    return out
